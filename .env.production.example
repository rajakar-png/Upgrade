# ─── Production Environment Configuration ──────────────────────────────────
# Copy this file to backend/.env and fill in all required values.
# Variables marked [REQUIRED] must be set. Others have working defaults.

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://yourdomain.com          # [REQUIRED] Your site's public URL

# ─── Database (auto-set by docker-compose, override for external DB) ────────
# DATABASE_URL=postgresql://astra:password@postgres:5432/astra

# ─── Redis (auto-set by docker-compose, override for external Redis) ────────
# REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                                  # [REQUIRED] Min 32 chars, generate: openssl rand -base64 48
JWT_EXPIRES_IN=12h

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                            # [REQUIRED for Google login]
GOOGLE_CLIENT_SECRET=                        # [REQUIRED for Google login]
DISCORD_CLIENT_ID=                           # [REQUIRED for Discord login]
DISCORD_CLIENT_SECRET=                       # [REQUIRED for Discord login]
OAUTH_CALLBACK_URL=https://yourdomain.com    # Must match your app's public URL

# ─── Pterodactyl ──────────────────────────────────────────────────────────────
PTERODACTYL_URL=https://panel.yourdomain.com # [REQUIRED] Pterodactyl panel URL
PTERODACTYL_API_KEY=ptla_xxxxx               # [REQUIRED] Application API key
PTERODACTYL_DEFAULT_EGG=1
PTERODACTYL_DEFAULT_DOCKER_IMAGE=ghcr.io/pterodactyl/yolks:java_17
PTERODACTYL_DEFAULT_STARTUP=java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}
PTERODACTYL_DEFAULT_ENV={}

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Discord Webhooks ─────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=                         # Optional: webhook for notifications
DISCORD_SUPPORT_WEBHOOK_URL=                 # Optional: webhook for support tickets

# ─── UPI Payments ─────────────────────────────────────────────────────────────
UPI_ID=                                      # [REQUIRED for UPI payments]
UPI_NAME=                                    # Name shown on UPI payment screen

# ─── Cloudflare (for subdomain DNS) ──────────────────────────────────────────
CLOUDFLARE_API_TOKEN=                        # [REQUIRED for subdomains]
CLOUDFLARE_ZONE_ID=                          # Zone ID for your domain
CLOUDFLARE_DOMAIN=yourdomain.com             # Base domain for subdomains

# ─── Docker Compose Overrides ─────────────────────────────────────────────────
POSTGRES_USER=astra
POSTGRES_PASSWORD=                           # [REQUIRED] Database password
POSTGRES_DB=astra
HTTP_PORT=80                                 # Public-facing HTTP port
