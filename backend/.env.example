# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL (used by docker-compose) ──────────────────────────────────────
POSTGRES_USER=astra
POSTGRES_PASSWORD=
POSTGRES_DB=astra

# ─── Database (used by backend) ──────────────────────────────────────────────
# auto-filled by deploy.sh from POSTGRES_* values above
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# auto-filled by deploy.sh if left empty
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── OAuth (optional — leave blank to disable) ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_CALLBACK_URL=

# ─── Pterodactyl (required) ──────────────────────────────────────────────────
PTERODACTYL_URL=
PTERODACTYL_API_KEY=
PTERODACTYL_CLIENT_KEY=
PTERODACTYL_DEFAULT_EGG=1
PTERODACTYL_DEFAULT_DOCKER_IMAGE=ghcr.io/pterodactyl/yolks:java_17
PTERODACTYL_DEFAULT_STARTUP=java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}
PTERODACTYL_DEFAULT_ENV={}

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200

# ─── Discord Webhooks (optional) ──────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
DISCORD_SUPPORT_WEBHOOK_URL=

# ─── UPI Payments (optional) ──────────────────────────────────────────────────
UPI_ID=
UPI_NAME=

# ─── Cron ──────────────────────────────────────────────────────────────────────
BACKUP_CRON_CONCURRENCY=3
AUDIT_LOG_RETENTION_DAYS=90

# ─── Cloudflare (optional — for DNS + SSL) ────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=
