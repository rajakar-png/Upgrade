# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/astranodes

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-long-secret
JWT_EXPIRES_IN=7d

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:4000

# ─── Pterodactyl ──────────────────────────────────────────────────────────────
PTERODACTYL_URL=https://panel.example.com
PTERODACTYL_API_KEY=ptla_xxx
PTERODACTYL_CLIENT_KEY=ptlc_xxx
PTERODACTYL_DEFAULT_EGG=1
PTERODACTYL_DEFAULT_DOCKER_IMAGE=ghcr.io/pterodactyl/yolks:java_17
PTERODACTYL_DEFAULT_STARTUP=java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}
PTERODACTYL_DEFAULT_ENV={}

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200

# ─── Discord Webhooks ─────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
DISCORD_SUPPORT_WEBHOOK_URL=

# ─── UPI Payments ─────────────────────────────────────────────────────────────
UPI_ID=
UPI_NAME=

# ─── Cron ──────────────────────────────────────────────────────────────────────
BACKUP_CRON_CONCURRENCY=3
AUDIT_LOG_RETENTION_DAYS=90

# ─── Cloudflare (DNS + SSL) ────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=astranodes.cloud

# ─── Admin ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=
